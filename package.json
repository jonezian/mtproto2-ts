{
  "name": "kerainmtp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Full TypeScript MTProto 2.0 implementation for Kerain.online",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "lint": "eslint packages/*/src/**/*.ts scripts/**/*.ts",
    "generate": "tsx scripts/generate.ts",
    "fetch-schema": "tsx scripts/fetch-schema.ts",
    "diff-schema": "tsx scripts/diff-schema.ts",
    "update-schema": "tsx scripts/update-schema.ts",
    "clean": "rm -rf packages/*/dist node_modules/.cache"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
